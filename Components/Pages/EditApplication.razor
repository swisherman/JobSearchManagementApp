@page "/applications/edit/{Id}"
@rendermode InteractiveServer

@using JobSearchApp.Models
@using JobSearchApp.Services
@inject ApplicationRecordService ApplicationService
@inject JobPostingService JobPostingService
@inject NavigationManager Navigation

<PageTitle>Edit Application</PageTitle>

<MudText Typo="Typo.h4">Edit Application</MudText>

@if (application == null)
{
    <MudText>Loading...</MudText>
}
else
{
    <MudPaper Class="pa-4 mt-4">

        <MudSelect T="string" Label="Job Posting" Value="application.JobPostingId" ValueChanged="OnJobPostingChanged">
            @foreach (var job in jobPostings)
            {
                <MudSelectItem Value="@(job.Id ?? "")">
                    @job.Title - @job.CompanyName
                </MudSelectItem>
            }
        </MudSelect>

        <MudDatePicker Label="Date Applied" @bind-Date="dateApplied" />

        <MudSelect T="string" Label="Status" @bind-Value="application.Status">
            <MudSelectItem Value="@("Applied")">Applied</MudSelectItem>
            <MudSelectItem Value="@("Followed Up")">Followed Up</MudSelectItem>
            <MudSelectItem Value="@("Interviewing")">Interviewing</MudSelectItem>
            <MudSelectItem Value="@("Offer")">Offer</MudSelectItem>
            <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
            <MudSelectItem Value="@("Withdrawn")">Withdrawn</MudSelectItem>
        </MudSelect>

        <MudTextField Label="Resume Version" @bind-Value="application.ResumeVersion" />
        <MudTextField Label="Cover Letter Version" @bind-Value="application.CoverLetterVersion" />

        <MudDatePicker Label="Follow Up Date" @bind-Date="followUpDate" />

        <MudTextField Label="Contact Name" @bind-Value="application.ContactName" />
        <MudTextField Label="Contact Email" @bind-Value="application.ContactEmail" />

        <MudTextField Label="Notes" @bind-Value="application.Notes" Lines="5" />
        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6">Interviews</MudText>

        <MudDatePicker Label="Interview Date" @bind-Date="newInterviewDate" />

        <MudSelect T="string" Label="Interview Type" @bind-Value="newInterview.InterviewType">
            <MudSelectItem Value="@("Phone Screen")">Phone Screen</MudSelectItem>
            <MudSelectItem Value="@("Recruiter Call")">Recruiter Call</MudSelectItem>
            <MudSelectItem Value="@("Technical Interview")">Technical Interview</MudSelectItem>
            <MudSelectItem Value="@("Hiring Manager")">Hiring Manager</MudSelectItem>
            <MudSelectItem Value="@("Panel Interview")">Panel Interview</MudSelectItem>
            <MudSelectItem Value="@("Final Interview")">Final Interview</MudSelectItem>
        </MudSelect>

        <MudTextField Label="Interviewer Name" @bind-Value="newInterview.InterviewerName" />

        <MudSelect T="string" Label="Outcome" @bind-Value="newInterview.Outcome">
            <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
            <MudSelectItem Value="@("Passed")">Passed</MudSelectItem>
            <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
            <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
        </MudSelect>

        <MudTextField Label="Interview Notes" @bind-Value="newInterview.Notes" Lines="3" />

        <MudButton Color="Color.Secondary"
                   Variant="Variant.Filled"
                   Class="mt-3"
                   OnClick="AddInterview">
            Add Interview
        </MudButton>

        <MudTable Items="application.Interviews" Class="mt-4">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Interviewer</MudTh>
                <MudTh>Outcome</MudTh>
                <MudTh>Notes</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@context.InterviewDate.ToShortDateString()</MudTd>
                <MudTd>@context.InterviewType</MudTd>
                <MudTd>@context.InterviewerName</MudTd>
                <MudTd>@context.Outcome</MudTd>
                <MudTd>@context.Notes</MudTd>
                <MudTd>
                    <MudButton Size="Size.Small"
                               Color="Color.Error"
                               Variant="Variant.Outlined"
                               OnClick="@(() => RemoveInterview(context))">
                        Remove
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Class="mt-3"
                   OnClick="Save">
            Save
        </MudButton>

        <MudButton Color="Color.Secondary"
                   Variant="Variant.Outlined"
                   Class="mt-3 ml-2"
                   OnClick="Cancel">
            Cancel
        </MudButton>

    </MudPaper>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;
    private InterviewRecord newInterview = new();
    private DateTime? newInterviewDate = DateTime.Today;

    private ApplicationRecord? application;
    private List<JobPosting> jobPostings = new();

    private DateTime? dateApplied;
    private DateTime? followUpDate;

    protected override async Task OnInitializedAsync()
    {
        jobPostings = await JobPostingService.GetAsync();
        application = await ApplicationService.GetAsync(Id);

        if (application is not null)
        {
            dateApplied = application.DateApplied;
            followUpDate = application.FollowUpDate;
        }
    }

    private void OnJobPostingChanged(string jobPostingId)
    {
        if (application is null)
            return;

        application.JobPostingId = jobPostingId;

        var job = jobPostings.FirstOrDefault(j => j.Id == jobPostingId);

        application.JobTitle = job?.Title ?? "";
        application.CompanyId = job?.CompanyId ?? "";
        application.CompanyName = job?.CompanyName ?? "";
    }

    private async Task Save()
    {
        if (application is null || string.IsNullOrWhiteSpace(application.Id))
            return;

        application.DateApplied = dateApplied ?? DateTime.Today;
        application.FollowUpDate = followUpDate;

        await ApplicationService.UpdateAsync(application.Id, application);

        Navigation.NavigateTo("/applications");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/applications");
    }
    private void AddInterview()
    {
        if (application is null)
            return;

        newInterview.InterviewDate = newInterviewDate ?? DateTime.Today;

        application.Interviews.Add(new InterviewRecord
        {
            InterviewDate = newInterview.InterviewDate,
            InterviewType = newInterview.InterviewType,
            InterviewerName = newInterview.InterviewerName,
            Outcome = newInterview.Outcome,
            Notes = newInterview.Notes
        });

        newInterview = new InterviewRecord();
        newInterviewDate = DateTime.Today;
    }

    private void RemoveInterview(InterviewRecord interview)
    {
        if (application is null)
            return;

        application.Interviews.Remove(interview);
    }
}